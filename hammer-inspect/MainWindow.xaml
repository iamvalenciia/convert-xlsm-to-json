<?xml version="1.0" encoding="utf-8"?>
<Window
    x:Class="hammer_inspect.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:hammer_inspect"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Title="hammer inspect">

    <Window.SystemBackdrop>
        <MicaBackdrop />
    </Window.SystemBackdrop>

    <Grid RowDefinitions="Auto,Auto,Auto,*" Padding="24,20,24,24" RowSpacing="12">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <TextBlock Text="Hammer Inspect" Style="{ThemeResource TitleTextBlockStyle}" VerticalAlignment="Center"/>
            <TextBlock Text="·" Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
            <TextBlock Text="xlsm To JSON" Style="{ThemeResource SubtitleTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}" VerticalAlignment="Center"/>
        </StackPanel>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
            <Button x:Name="BtnSelect" Content="Select.xlsm File" Click="BtnSelect_Click"
                    Style="{ThemeResource AccentButtonStyle}"/>
            <TextBlock x:Name="TxtFilePath" Text="No file selected"
                       VerticalAlignment="Center" MaxWidth="260" TextTrimming="CharacterEllipsis"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
            <Border Width="1" Height="24" Background="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    VerticalAlignment="Center" Margin="4,0"/>
            <Button x:Name="BtnConvert" Content="Convert to JSON" Click="BtnConvert_Click" IsEnabled="False"/>
            <TextBlock x:Name="TxtStatus" Text="" VerticalAlignment="Center"
                       Style="{ThemeResource BodyTextBlockStyle}"
                       Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"/>
        </StackPanel>

        <Grid Grid.Row="2" Grid.RowSpan="2" RowDefinitions="Auto,Auto,Auto,*" RowSpacing="10"
              x:Name="PanelViewer" Visibility="Collapsed">

            <Grid Grid.Row="0" ColumnDefinitions="*,Auto,Auto" ColumnSpacing="10">
                <TextBox x:Name="TxtSearch"
                         Grid.Column="0"
                         PlaceholderText="Search across all sheets and columns..."
                         TextChanged="TxtSearch_TextChanged"
                         VerticalAlignment="Center"/>
                <TextBlock x:Name="TxtResultCount"
                           Grid.Column="1"
                           VerticalAlignment="Center"
                           Foreground="{ThemeResource SystemControlForegroundBaseMediumBrush}"
                           Style="{ThemeResource CaptionTextBlockStyle}"
                           Text=""/>
                <Button x:Name="BtnCopyResults"
                        Grid.Column="2"
                        Content="Copy Results"
                        Click="BtnCopyResults_Click"
                        IsEnabled="False"/>
            </Grid>

            <ScrollViewer Grid.Row="1"
                          HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Hidden"
                          Height="52"
                          Padding="0,4,0,4">
                <StackPanel x:Name="PanelSheetPills"
                            Orientation="Horizontal"
                            Spacing="6"
                            VerticalAlignment="Center"
                            Margin="0,0,0,0"/>
            </ScrollViewer>

            <Border Grid.Row="2" Height="1"
                    Background="{ThemeResource SystemControlForegroundBaseLowBrush}"/>

            <Border Grid.Row="3" CornerRadius="8"
                    BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                    BorderThickness="1">
                <ListView x:Name="LvResults"
                          SelectionMode="None"
                          IsItemClickEnabled="False"
                          ScrollViewer.VerticalScrollBarVisibility="Auto"
                          ScrollViewer.HorizontalScrollBarVisibility="Auto"
                          ScrollViewer.VerticalScrollMode="Enabled"
                          ScrollViewer.HorizontalScrollMode="Enabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="MinHeight" Value="0"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:ResultRow">
                            <Border BorderBrush="{ThemeResource SystemControlForegroundBaseLowBrush}"
                                    BorderThickness="0,0,0,1" Padding="12,8">
                                <StackPanel Spacing="3">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <Border Background="{ThemeResource AccentFillColorDefaultBrush}"
                                                CornerRadius="4" Padding="6,2">
                                            <TextBlock Text="{x:Bind SheetName}"
                                                       Style="{ThemeResource CaptionTextBlockStyle}"
                                                       Foreground="White" FontWeight="SemiBold"/>
                                        </Border>
                                        <HyperlinkButton Content="{x:Bind RowLabel}"
                                                         Click="BtnRowDetails_Click"
                                                         Style="{ThemeResource DefaultHyperlinkButtonStyle}"
                                                         Foreground="{ThemeResource AccentFillColorDefaultBrush}"
                                                         VerticalAlignment="Center"
                                                         Padding="0" MinWidth="0" MinHeight="0" Margin="0"/>
                                    </StackPanel>
                                    <TextBlock Text="{x:Bind MatchSummary}"
                                               Style="{ThemeResource BodyTextBlockStyle}"
                                               TextWrapping="Wrap" MaxWidth="1200"/>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Border>
        </Grid>
    </Grid>
</Window>
